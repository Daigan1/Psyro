# AWS
AWS_REGION=us-east-1

# Cognito — single user pool with groups: client, provider
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_APP_ID=
COGNITO_PROVIDER_APP_ID=

# DynamoDB
DDB_TABLE_USERS=tinyfish_users
DDB_TABLE_APPOINTMENTS=tinyfish_appointments
DDB_TABLE_SESSION_ARTIFACTS=tinyfish_session_artifacts
DDB_TABLE_RESOURCES=tinyfish_resources

# S3 — session recordings, uploaded resources (KMS-encrypted bucket, 7yr lifecycle)
S3_BUCKET_PHI=

# TinyFish Fetch API — renders URLs (HTML + PDF) in a real browser and returns
# clean extracted text. Used to ingest therapist-uploaded resources (URLs and
# PDFs) so the AI Q&A tools can answer from that content.
# Get a key at https://agent.tinyfish.ai/api-keys
TINYFISH_API_KEY=
TINYFISH_FETCH_URL=https://api.fetch.tinyfish.ai

# Featherless AI (public models) — therapist matcher only.
# Structured intake + provider data in, tool-call JSON out.
# Transcripts and summaries do NOT route through Featherless.
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL_MATCHER=

# ElevenLabs — STT (session transcription AND draft summary; the STT tool
# owns both) + ElevenAgents for post-session Q&A only. There is no
# separate summarizer agent. Confirm PHI handling with vendor before live use.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENAGENTS_QA_AGENT_ID=

# Chime SDK
CHIME_MEDIA_REGION=us-east-1

# Feature flag: use live AWS clients vs local mocks
USE_AWS=false

# HMAC secret used to sign the local tf_session cookie. REQUIRED in production;
# dev falls back to a fixed string if unset. When Cognito is wired
# (USE_AWS=true), sessions switch to Cognito-issued JWTs and this is unused.
AUTH_SECRET=dev-only-change-me-in-prod-xxxxxxxxxxxxxxxx

# Stripe — use test-mode (sandbox) keys for dev: sk_test_... / whsec_...
# Webhook secret comes from `stripe listen` CLI output or the Dashboard endpoint.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Base URL used to build Checkout success/cancel URLs.
APP_BASE_URL=http://localhost:3000
